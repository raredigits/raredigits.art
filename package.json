{
  "name": "raredigits.art",
  "version": "0.6.17",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "start": "npm-run-all charts:build --parallel sass-watch charts:watch eleventy-serve",
    "build": "npm run sass-build && npm run charts:build && eleventy",
    "postbuild": "npm run pagefind:build",
    "build:css": "sass assets/css/rare.scss assets/css/rare.css && sass assets/css/rare.scss assets/css/rare.min.css --style=compressed",
    "lint:css": "stylelint \"assets/css/**/*.scss\"",
    "watch:css": "sass --watch --poll assets/css/rare.scss:assets/css/rare.css",
    "watch:css:min": "sass --watch --poll assets/css/rare.scss:assets/css/rare.min.css --style=compressed",
    "sass-watch": "npm-run-all --parallel watch:css watch:css:min",
    "sass-watch-readable": "npm run watch:css",
    "sass-watch-minified": "npm run watch:css:min",
    "sass-build": "npm run build:css",
    "charts:build": "node scripts/build-charts.mjs",
    "charts:build:min": "node scripts/build-charts.mjs",
    "charts:watch": "node scripts/build-charts.mjs --watch",
    "eleventy-serve": "eleventy --serve",
    "pagefind:build": "pagefind --site _site",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raredigits/raredigits.art.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/raredigits/raredigits.art/issues"
  },
  "homepage": "https://github.com/raredigits/raredigits.art#readme",
  "description": "",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "d3": "^7.9.0",
    "esbuild": "^0.28.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.14",
    "postcss-scss": "^4.0.9",
    "sass": "^1.99.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "topojson-client": "^3.1.0",
    "vitest": "^4.1.9",
    "world-atlas": "^2.0.2"
  }
}
