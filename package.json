{
  "name": "raredigits.art",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "npm-run-all charts:build --parallel sass-watch charts:watch eleventy-serve",
    "build": "npm run sass-build && npm run charts:build && eleventy",
    "postbuild": "npm run pagefind:build",
    "sass-watch": "npm-run-all --parallel sass-watch-readable sass-watch-minified",
    "sass-watch-readable": "sass --watch assets/css/rare.scss:assets/css/rare.css",
    "sass-watch-minified": "sass --watch assets/css/rare.scss:assets/css/rare.min.css --style=compressed",
    "sass-build": "sass assets/css/rare.scss assets/css/rare.css && sass assets/css/rare.scss assets/css/rare.min.css --style=compressed",
    "charts:build": "esbuild assets/charts/src/index.js --bundle --format=iife --global-name=RareCharts --loader:.css=text --outfile=assets/charts/rare-charts.js",
    "charts:build:min": "esbuild assets/charts/src/index.js --bundle --minify --format=iife --global-name=RareCharts --loader:.css=text --outfile=assets/charts/rare-charts.min.js",
    "charts:watch": "esbuild assets/charts/src/index.js --bundle --format=iife --global-name=RareCharts --loader:.css=text --outfile=assets/charts/rare-charts.js --watch",
    "eleventy-serve": "eleventy --serve",
    "pagefind:build": "pagefind --site _site"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raredigits/raredigits.art.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/raredigits/raredigits.art/issues"
  },
  "homepage": "https://github.com/raredigits/raredigits.art#readme",
  "description": "",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "d3": "^7.9.0",
    "esbuild": "^0.24.0",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.4.0",
    "sass": "^1.86.3",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  }
}
